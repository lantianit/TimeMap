.container { width: 100%; height: 100vh; position: relative; }
.map { width: 100%; height: 100%; }

/* ===== 顶部轻提示 ===== */
.top-toast {
  position: fixed; top: -100rpx; left: 40rpx; right: 40rpx; z-index: 200;
  background: rgba(0,0,0,0.75); color: #fff; font-size: 26rpx;
  padding: 18rpx 30rpx; border-radius: 12rpx; text-align: center;
  transition: top 0.3s ease;
}
.top-toast.show { top: calc(env(safe-area-inset-top) + 20rpx); }

/* ===== 时光筛选胶囊（优化点1） ===== */
.filter-capsule {
  position: fixed; top: calc(env(safe-area-inset-top) + 100rpx);
  left: 20rpx; z-index: 100;
  height: 60rpx; padding: 0 24rpx;
  background: rgba(0,0,0,0.6); border-radius: 30rpx;
  display: flex; align-items: center; gap: 8rpx;
}
.filter-icon { font-size: 26rpx; }
.filter-text { color: #fff; font-size: 24rpx; font-weight: 600; }

/* ===== 一键定位按钮（优化点2） ===== */
.locate-btn {
  position: fixed; right: 30rpx; bottom: 260rpx; z-index: 100;
  width: 80rpx; height: 80rpx;
  background: #fff; border-radius: 50%;
  border: 2rpx solid #e0e0e0;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
  display: flex; align-items: center; justify-content: center;
}
.locate-btn.disabled { opacity: 0.4; }
.locate-arrow {
  width: 0; height: 0;
  border-left: 12rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-bottom: 20rpx solid #4285f4;
  position: relative; top: -4rpx;
}
.locate-arrow::after {
  content: ''; position: absolute;
  top: 10rpx; left: -6rpx;
  width: 12rpx; height: 12rpx;
  background: #4285f4; border-radius: 50%;
}

/* ===== 筛选面板 ===== */
.filter-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.3); z-index: 150;
}
.filter-panel {
  position: fixed; bottom: -500rpx; left: 0; right: 0; z-index: 160;
  background: #fff; border-radius: 32rpx 32rpx 0 0;
  padding: 30rpx; padding-bottom: calc(env(safe-area-inset-bottom) + 30rpx);
  transition: bottom 0.3s ease;
}
.filter-panel.show { bottom: 0; }
.filter-panel-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 30rpx;
}
.filter-panel-title { font-size: 32rpx; font-weight: 600; color: #333; }
.filter-panel-close { font-size: 32rpx; color: #999; padding: 10rpx; }
.filter-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 0; border-bottom: 1rpx solid #f0f0f0;
}
.filter-label { font-size: 28rpx; color: #666; }
.filter-date-btn {
  font-size: 28rpx; color: #333; background: #f5f5f5;
  padding: 12rpx 24rpx; border-radius: 8rpx;
}
.filter-actions {
  display: flex; gap: 20rpx; margin-top: 30rpx;
}
.filter-reset-btn {
  flex: 1; text-align: center; padding: 20rpx 0;
  font-size: 28rpx; color: #666; background: #f5f5f5;
  border-radius: 12rpx;
}
.filter-confirm-btn {
  flex: 2; text-align: center; padding: 20rpx 0;
  font-size: 28rpx; color: #fff; font-weight: 600;
  background: #07c160; border-radius: 12rpx;
}

/* ===== 底部操作栏 ===== */
.action-bar {
  position: fixed; bottom: -300rpx; left: 0; right: 0; z-index: 90;
  transition: bottom 0.3s ease;
}
.action-bar.show { bottom: 0; }
.action-bar-inner {
  margin: 0 20rpx; margin-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border-radius: 16rpx; padding: 24rpx 28rpx;
  box-shadow: 0 -4rpx 30rpx rgba(0,0,0,0.08);
  display: flex; align-items: center; justify-content: space-between;
}
.action-location { flex: 1; min-width: 0; }
.location-text {
  font-size: 24rpx; color: #333;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  display: block;
}
.action-date {
  padding: 8rpx 20rpx; background: #f5f5f5;
  border-radius: 20rpx; flex-shrink: 0; margin: 0 16rpx;
}
.date-text { font-size: 24rpx; color: #333; }
.action-buttons { display: flex; align-items: center; flex-shrink: 0; gap: 16rpx; }
.btn-cancel { font-size: 26rpx; color: #999; padding: 10rpx 16rpx; }
.btn-upload {
  background: #07c160; color: #fff; font-size: 26rpx; font-weight: 600;
  padding: 16rpx 36rpx; border-radius: 30rpx;
}
.btn-upload.disabled { opacity: 0.5; }

/* ===== 底部提示 ===== */
.hint-bar {
  position: fixed; bottom: calc(env(safe-area-inset-bottom) + 130rpx);
  left: 50%; transform: translateX(-50%);
  background: rgba(0,0,0,0.55); color: #fff; font-size: 24rpx;
  padding: 14rpx 36rpx; border-radius: 30rpx;
}
