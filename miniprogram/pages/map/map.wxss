.container { width: 100%; height: 100vh; position: relative; }
.map { width: 100%; height: 100%; }

/* 顶部轻提示 */
.top-toast {
  position: fixed; top: -100rpx; left: 40rpx; right: 40rpx; z-index: 100;
  background: rgba(0,0,0,0.75); color: #fff; font-size: 26rpx;
  padding: 20rpx 30rpx; border-radius: 12rpx; text-align: center;
  transition: top 0.3s ease;
}
.top-toast.show { top: calc(env(safe-area-inset-top) + 20rpx); }

/* 底部操作栏 */
.action-bar {
  position: fixed; bottom: -300rpx; left: 0; right: 0; z-index: 90;
  transition: bottom 0.3s ease;
}
.action-bar.show { bottom: 0; }
.action-bar-inner {
  margin: 0 20rpx; margin-bottom: calc(env(safe-area-inset-bottom) + 20rpx);
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border-radius: 16rpx; padding: 24rpx 28rpx;
  box-shadow: 0 -4rpx 30rpx rgba(0,0,0,0.08);
  display: flex; align-items: center; justify-content: space-between;
}

/* 位置信息 */
.action-location { display: flex; align-items: center; flex: 1; min-width: 0; }
.location-icon { font-size: 28rpx; margin-right: 8rpx; flex-shrink: 0; }
.location-text {
  font-size: 24rpx; color: #666;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}

/* 日期选择 */
.action-date { display: flex; align-items: center; padding: 0 20rpx; flex-shrink: 0; }
.date-icon { font-size: 28rpx; margin-right: 8rpx; }
.date-text { font-size: 26rpx; color: #333; font-weight: 500; }

/* 操作按钮 */
.action-buttons { display: flex; align-items: center; flex-shrink: 0; gap: 16rpx; }
.btn-cancel { font-size: 26rpx; color: #999; padding: 10rpx 16rpx; }
.btn-upload {
  background: #07c160; color: #fff; font-size: 26rpx; font-weight: 500;
  padding: 14rpx 32rpx; border-radius: 30rpx;
}
.btn-upload.disabled { opacity: 0.5; }

/* 底部提示 */
.hint-bar {
  position: fixed; bottom: calc(env(safe-area-inset-bottom) + 30rpx);
  left: 50%; transform: translateX(-50%);
  background: rgba(0,0,0,0.55); color: #fff; font-size: 24rpx;
  padding: 14rpx 36rpx; border-radius: 30rpx;
}
