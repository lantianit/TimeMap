.page { min-height: 100vh; background: #f5f5f5; padding: 24rpx; box-sizing: border-box; }
.empty, .loading { text-align: center; color: #999; font-size: 28rpx; padding: 120rpx 0; }

.card {
  background: #fff; border-radius: 20rpx;
  padding: 24rpx; margin-bottom: 16rpx;
}

.card-top {
  display: flex; justify-content: space-between;
  align-items: center; margin-bottom: 10rpx;
}

.action-tag {
  font-size: 26rpx; font-weight: 500;
  color: #07c160; background: rgba(7,193,96,0.08);
  padding: 6rpx 16rpx; border-radius: 8rpx;
}

.time { font-size: 22rpx; color: #bbb; }
.meta { font-size: 24rpx; color: #666; margin-top: 6rpx; }

.detail {
  margin-top: 10rpx; padding: 16rpx;
  background: #f8f9fb; border-radius: 12rpx;
  font-size: 22rpx; color: #333; line-height: 1.7;
  word-break: break-all;
}
