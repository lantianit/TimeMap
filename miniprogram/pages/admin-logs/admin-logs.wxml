<view class="page">
  <view class="empty" wx:if="{{!logs.length && !loading}}">
    <text>暂无操作日志</text>
  </view>

  <view wx:if="{{logs.length}}">
    <view class="card" wx:for="{{logs}}" wx:key="id">
      <view class="card-top">
        <text class="action-tag">{{item.actionLabel}}</text>
        <text class="time">{{item.createTimeLabel}}</text>
      </view>
      <view class="meta">
        <text>操作人：{{item.adminNickname || '管理员'}}</text>
      </view>
      <view class="detail" wx:if="{{item.detail}}">
        <text>{{item.detail}}</text>
      </view>
    </view>
  </view>

  <view class="loading" wx:if="{{loading}}"><text>加载中...</text></view>
  <view class="loading" wx:if="{{!hasMore && logs.length}}"><text>没有更多了</text></view>
</view>
