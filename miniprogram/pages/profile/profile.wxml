<view class="container">
  <!-- 未登录 -->
  <view wx:if="{{!isLoggedIn}}" class="login-section">
    <view class="login-header">
      <view class="logo-circle">
        <text class="logo-text">时迹</text>
      </view>
      <text class="app-name">时迹地图</text>
      <text class="app-desc">记录城市的每一刻</text>
    </view>
    <view class="login-features">
      <view class="feature-item">
        <text class="feature-icon">📷</text>
        <text class="feature-text">拍摄城市照片</text>
      </view>
      <view class="feature-item">
        <text class="feature-icon">🗺️</text>
        <text class="feature-text">地图浏览记忆</text>
      </view>
      <view class="feature-item">
        <text class="feature-icon">⏰</text>
        <text class="feature-text">时间轴回顾</text>
      </view>
    </view>
    <button class="login-btn" bindtap="onLogin">微信一键登录</button>
    <text class="login-hint">登录即表示同意《用户协议》和《隐私政策》</text>
  </view>

  <!-- 已登录 -->
  <view wx:if="{{isLoggedIn}}">
    <view class="user-card">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/icon-user.svg'}}" mode="aspectFill" />
      <view class="user-main">
        <view class="user-info">
          <text class="nickname">{{userInfo.nickname || '微信用户'}}</text>
          <text class="user-summary" wx:if="{{userInfo.photoCount > 0}}">
            已留下 {{userInfo.photoCount || 0}} 张照片，足迹覆盖 {{userInfo.areaCount || 0}} 个区域
          </text>
          <text class="user-summary" wx:else>去地图上传第一张照片，开始记录你的城市足迹</text>
        </view>
        <view class="summary-grid">
          <view class="summary-item">
            <text class="summary-value">{{userInfo.photoCount || 0}}</text>
            <text class="summary-label">照片</text>
          </view>
          <view class="summary-item">
            <text class="summary-value">{{userInfo.areaCount || 0}}</text>
            <text class="summary-label">区域</text>
          </view>
          <view class="summary-item">
            <text class="summary-value">{{userInfo.likeCount || 0}}</text>
            <text class="summary-label">获赞</text>
          </view>
        </view>
        <view class="recent-row" wx:if="{{userInfo.latestPhotoDate}}">
          <text class="recent-tag">最近记录</text>
          <text class="recent-date">{{userInfo.latestPhotoDate}}</text>
        </view>
      </view>
    </view>

    <view class="menu-list">
      <view class="menu-item" bindtap="onGoMessages">
        <text class="menu-icon">💬</text>
        <text class="menu-text">我的消息</text>
        <view class="menu-badge" wx:if="{{unreadCount > 0}}">
          <text>{{unreadCount > 99 ? '99+' : unreadCount}}</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="area-card" wx:if="{{topAreas.length}}">
      <view class="section-head">
        <text class="section-title">足迹亮点</text>
        <text class="section-subtitle">按上传区域统计</text>
      </view>
      <view class="area-list">
        <view class="area-item" wx:for="{{topAreas}}" wx:key="name">
          <view class="area-item-main">
            <text class="area-name">{{item.name}}</text>
            <text class="area-count">{{item.count}} 张</text>
          </view>
          <view class="area-progress">
            <view class="area-progress-inner" style="width: {{photoTotal ? (item.count / photoTotal * 100) : 0}}%;"></view>
          </view>
        </view>
      </view>
    </view>

    <view class="section-head photo-section-head">
      <text class="section-title">我的拍摄</text>
      <text class="section-subtitle" wx:if="{{photoTotal > 0}}">共 {{photoTotal}} 张</text>
    </view>

    <!-- 照片网格 -->
    <view class="photo-grid" wx:if="{{photos.length}}">
      <view class="photo-cell" wx:for="{{photos}}" wx:key="id" bindtap="onPhotoTap" data-id="{{item.id}}">
        <image class="photo-thumb" src="{{item.thumbnailUrl || item.imageUrl}}" mode="aspectFill" />
        <view class="photo-meta">
          <text class="photo-loc">{{item.locationName}}</text>
          <view class="photo-bottom">
            <text class="photo-date">{{item.photoDateLabel}}</text>
            <view class="photo-stats">
              <text wx:if="{{item.likeCount > 0}}">♥ {{item.likeCount}}</text>
              <text wx:if="{{item.commentCount > 0}}">💬 {{item.commentCount}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-tip" wx:if="{{!photos.length && !photoLoading}}">还没有拍摄记录，去地图上传第一张吧</view>
    <view class="loading-tip" wx:if="{{photoLoading}}">加载中...</view>
    <view class="loading-tip" wx:if="{{!photoHasMore && photos.length}}">没有更多了</view>

    <button class="logout-btn" bindtap="onLogout">退出登录</button>
  </view>
</view>
