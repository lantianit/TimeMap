page {
  background: #ededed;
}

.chat-page {
  min-height: 100%;
  background: #ededed;
}

.msg-list {
  padding: 24rpx 24rpx 32rpx;
  box-sizing: border-box;
}

.load-more {
  text-align: center;
  padding: 12rpx 0 20rpx;
  color: #999;
  font-size: 24rpx;
}

.chat-time {
  display: flex;
  justify-content: center;
  margin: 12rpx 0 24rpx;
}

.chat-time-text {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #999;
  background: rgba(0, 0, 0, 0.06);
}

.msg-empty {
  text-align: center;
  padding: 180rpx 0;
  color: #999;
  font-size: 26rpx;
}

.msg-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.msg-row.mine {
  flex-direction: row-reverse;
}

.msg-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #dcdcdc;
}

.msg-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8e8e8e;
  font-size: 28rpx;
  font-weight: 500;
}

.msg-avatar-fallback-text {
  line-height: 1;
}

.msg-bubble-wrap {
  max-width: 66%;
  margin: 0 18rpx;
}

.msg-row.mine .msg-bubble-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.msg-bubble {
  display: inline-block;
  max-width: 100%;
  padding: 18rpx 22rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  line-height: 1.5;
  white-space: pre-wrap;
  word-break: break-all;
  overflow-wrap: anywhere;
  box-sizing: border-box;
}

.bubble-other {
  background: #fff;
  color: #111;
  box-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.04);
}

.bubble-mine {
  background: #95ec69;
  color: #111;
}

.msg-status {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #999;
  line-height: 1.4;
}

.msg-row.mine .msg-status {
  text-align: right;
}

.msg-sending {
  display: inline-block;
}

.msg-fail {
  color: #ff4d4f;
  margin-left: 12rpx;
}

.chat-input-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  box-sizing: border-box;
  background: #f7f7f7;
  border-top: 1rpx solid #d8d8d8;
  z-index: 100;
}

.chat-input-wrap {
  flex: 1;
  min-height: 72rpx;
  background: #fff;
  border-radius: 10rpx;
  border: 1rpx solid #e5e5e5;
}

.chat-input {
  flex: 1;
  height: 72rpx;
  width: 100%;
  background: transparent;
  padding: 14rpx 20rpx;
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

.chat-send {
  margin-left: 16rpx;
  width: 110rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 30rpx;
  color: #b4b4b4;
  flex-shrink: 0;
  border-radius: 10rpx;
  background: #e9e9e9;
}

.chat-send.active {
  color: #fff;
  font-weight: 500;
  background: #07c160;
}
