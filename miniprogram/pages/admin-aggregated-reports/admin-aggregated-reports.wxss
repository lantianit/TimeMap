.page { min-height: 100vh; background: #f5f5f5; padding: 24rpx; box-sizing: border-box; }
.empty, .loading { text-align: center; color: #999; font-size: 28rpx; padding: 120rpx 0; }

.card {
  background: #fff; border-radius: 20rpx;
  padding: 28rpx; margin-bottom: 20rpx;
}

.card-top { margin-bottom: 16rpx; }
.title { font-size: 30rpx; font-weight: 600; color: #333; }

.card-body { display: flex; gap: 16rpx; }
.thumb {
  width: 120rpx; height: 120rpx; border-radius: 12rpx;
  flex-shrink: 0; background: #f0f0f0;
}
.info { flex: 1; min-width: 0; }
.preview {
  font-size: 26rpx; color: #333; margin-bottom: 8rpx;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.meta { font-size: 22rpx; color: #666; margin-top: 4rpx; line-height: 1.6; }

.action-row { margin-top: 16rpx; display: flex; justify-content: flex-end; }
.action-btn {
  padding: 12rpx 28rpx; border-radius: 999rpx;
  background: #07c160; color: #fff; font-size: 24rpx;
}
