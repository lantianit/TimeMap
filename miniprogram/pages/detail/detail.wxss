.container {
  padding: 30rpx;
}

.photo-area {
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
}

.photo-swiper {
  width: 100%;
  height: 560rpx;
}

.photo {
  width: 100%;
  height: 100%;
}

.photo-counter {
  position: absolute;
  top: 20rpx; right: 20rpx;
  background: rgba(0,0,0,0.5);
  color: #fff; font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  text-align: right;
  margin-left: 20rpx;
}

.desc-value {
  text-align: left;
  word-break: break-all;
  flex: 1;
}

.location-row .info-value-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-left: 20rpx;
}

.location-row .info-value {
  margin-left: 0;
}

.location-map-btn {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0f9f0;
  border-radius: 50%;
  flex-shrink: 0;
}

.location-map-btn:active {
  opacity: 0.6;
}

.location-map-icon {
  width: 32rpx;
  height: 32rpx;
}

/* ========== 评论区 ========== */
.comment-section {
  margin-top: 30rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.comment-header {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.comment-empty {
  text-align: center;
  padding: 60rpx 0;
  color: #bbb;
  font-size: 26rpx;
}

.comment-loading {
  text-align: center;
  padding: 30rpx 0;
  color: #bbb;
  font-size: 24rpx;
}

.comment-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-right: 20rpx;
  background: #f0f0f0;
}

.comment-body {
  flex: 1;
  min-width: 0;
}

.comment-top {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}

.comment-nick {
  font-size: 26rpx;
  color: #576b95;
  font-weight: 500;
  margin-right: 12rpx;
}

.comment-time {
  font-size: 22rpx;
  color: #bbb;
}

.comment-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  word-break: break-all;
}

.comment-actions {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  gap: 32rpx;
}

.comment-like {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: #999;
}

.comment-like.liked {
  color: #ff4d4f;
}

.comment-reply-btn {
  font-size: 24rpx;
  color: #999;
}

.comment-expand {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #576b95;
}

/* 子评论 */
.reply-item {
  display: flex;
  padding: 16rpx 0;
  margin-left: 0;
  background: #fafafa;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-top: 12rpx;
}

.reply-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-right: 16rpx;
  background: #f0f0f0;
}

.reply-body {
  flex: 1;
  min-width: 0;
}

.reply-to {
  font-size: 24rpx;
  color: #576b95;
  margin-right: 8rpx;
}

/* ========== 底部输入栏 ========== */
.input-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #eee;
  z-index: 100;
}

.input-bar-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-right: 16rpx;
  background: #f0f0f0;
}

.input-bar-input {
  flex: 1;
  height: 68rpx;
  background: #f5f5f5;
  border-radius: 34rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
}

.input-bar-send {
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #bbb;
  flex-shrink: 0;
}

.input-bar-send.active {
  color: #07c160;
  font-weight: 500;
}
