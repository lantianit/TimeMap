.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  box-sizing: border-box;
}

.empty,
.loading {
  padding: 120rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.target {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.status {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}

.status-0 { color: #fa8c16; background: rgba(250,140,22,0.12); }
.status-1 { color: #07c160; background: rgba(7,193,96,0.12); }
.status-2 { color: #666; background: #f0f0f0; }

.card-content {
  display: flex;
  gap: 16rpx;
}

.thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.card-info {
  flex: 1;
  min-width: 0;
}

.preview {
  font-size: 24rpx;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.row {
  display: flex;
  margin-top: 6rpx;
}

.label {
  width: 80rpx;
  color: #999;
  font-size: 24rpx;
  flex-shrink: 0;
}

.value {
  flex: 1;
  color: #333;
  font-size: 24rpx;
  line-height: 1.6;
}

.result {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f8f9fb;
}

.result-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.result-text {
  font-size: 24rpx;
  color: #333;
  line-height: 1.6;
}

.appeal-btn {
  margin-top: 16rpx;
  text-align: center;
  height: 64rpx;
  line-height: 64rpx;
  background: #f6fbf8;
  color: #07c160;
  border-radius: 32rpx;
  font-size: 26rpx;
}

/* 申诉弹窗 */
.report-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.report-dialog {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
}

.report-dialog-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.report-dialog-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  box-sizing: border-box;
  background: #f5f5f5;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
}

.report-dialog-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.report-dialog-btn {
  flex: 1;
  text-align: center;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.report-dialog-btn.cancel { background: #f5f5f5; color: #666; }
.report-dialog-btn.confirm { background: #07c160; color: #fff; }
