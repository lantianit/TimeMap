.messages-page {
  min-height: 100vh;
  background: #f5f5f5;
}

.conv-empty {
  text-align: center;
  padding: 120rpx 0;
  color: #bbb;
  font-size: 28rpx;
}

.conv-loading {
  text-align: center;
  padding: 30rpx 0;
  color: #bbb;
  font-size: 24rpx;
}

.conv-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.conv-avatar-wrap {
  position: relative;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.conv-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #e8e8e8;
}

.conv-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  background: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  border-radius: 18rpx;
  padding: 0 8rpx;
}

.conv-body {
  flex: 1;
  min-width: 0;
}

.conv-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.conv-nick {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 400rpx;
}

.conv-time {
  font-size: 22rpx;
  color: #bbb;
  flex-shrink: 0;
}

.conv-last {
  font-size: 26rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
