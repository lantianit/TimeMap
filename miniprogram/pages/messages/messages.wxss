.messages-page { min-height: 100vh; background: #f5f5f5; }

/* Tab 栏 */
.tab-bar {
  display: flex; background: #fff; border-bottom: 1rpx solid #eee;
  position: sticky; top: 0; z-index: 10;
}
.tab-item {
  flex: 1; text-align: center; padding: 24rpx 0;
  font-size: 30rpx; color: #666; position: relative;
}
.tab-item.active { color: #07c160; font-weight: 600; }
.tab-item.active::after {
  content: ''; position: absolute; bottom: 0; left: 50%;
  transform: translateX(-50%); width: 60rpx; height: 4rpx;
  background: #07c160; border-radius: 2rpx;
}
.tab-badge {
  position: absolute; top: 10rpx; right: 50%; margin-right: -60rpx;
  min-width: 32rpx; height: 32rpx; line-height: 32rpx;
  text-align: center; background: #ff4d4f; color: #fff;
  font-size: 18rpx; border-radius: 16rpx; padding: 0 6rpx;
}

/* 私信列表 */
.conv-empty { text-align: center; padding: 120rpx 0; color: #bbb; font-size: 28rpx; }
.conv-loading { text-align: center; padding: 30rpx 0; color: #bbb; font-size: 24rpx; }
.conv-item {
  display: flex; align-items: center; padding: 28rpx 30rpx;
  background: #fff; border-bottom: 1rpx solid #f0f0f0;
}
.conv-avatar-wrap { position: relative; flex-shrink: 0; margin-right: 24rpx; }
.conv-avatar { width: 88rpx; height: 88rpx; border-radius: 50%; background: #e8e8e8; }
.conv-badge {
  position: absolute; top: -8rpx; right: -8rpx;
  min-width: 36rpx; height: 36rpx; line-height: 36rpx;
  text-align: center; background: #ff4d4f; color: #fff;
  font-size: 20rpx; border-radius: 18rpx; padding: 0 8rpx;
}
.conv-body { flex: 1; min-width: 0; }
.conv-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.conv-nick {
  font-size: 30rpx; color: #333; font-weight: 500;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 400rpx;
}
.conv-time { font-size: 22rpx; color: #bbb; flex-shrink: 0; }
.conv-last { font-size: 26rpx; color: #999; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* 互动通知 */
.notif-read-all {
  text-align: right; padding: 16rpx 30rpx;
  font-size: 24rpx; color: #07c160; background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}
.notif-item {
  display: flex; align-items: center; padding: 28rpx 30rpx;
  background: #fff; border-bottom: 1rpx solid #f0f0f0;
}
.notif-item.unread { background: #f0faf4; }
.notif-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; flex-shrink: 0; margin-right: 20rpx; background: #e8e8e8; }
.notif-body { flex: 1; min-width: 0; }
.notif-top { display: flex; align-items: center; flex-wrap: wrap; margin-bottom: 6rpx; }
.notif-nick { font-size: 28rpx; color: #333; font-weight: 500; margin-right: 8rpx; }
.notif-action { font-size: 26rpx; color: #666; }
.notif-content {
  font-size: 24rpx; color: #999; margin-bottom: 4rpx;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.notif-time { font-size: 22rpx; color: #bbb; }
.notif-photo {
  width: 88rpx; height: 88rpx; border-radius: 8rpx;
  flex-shrink: 0; margin-left: 16rpx; background: #f0f0f0;
}
