.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.shortcuts {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx 0;
  background: #fff;
}

.shortcut-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  background: #f6fbf8;
  color: #07c160;
  border-radius: 12rpx;
  font-size: 24rpx;
}

.tabs {
  display: flex;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
  border-bottom: 1rpx solid #eee;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  color: #666;
  font-size: 28rpx;
  position: relative;
}

.tab.active {
  color: #07c160;
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  left: 50%; bottom: 0;
  transform: translateX(-50%);
  width: 60rpx; height: 4rpx;
  border-radius: 999rpx;
  background: #07c160;
}

.type-tabs {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 12rpx 24rpx;
  gap: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.type-tab {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
}

.type-tab.active {
  color: #07c160;
  background: rgba(7,193,96,0.1);
}

.batch-toggle {
  margin-left: auto;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #576b95;
  background: #f0f4ff;
}

.empty, .loading {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 120rpx 24rpx;
}

.card {
  margin: 20rpx 24rpx 0;
  padding: 26rpx;
  border-radius: 20rpx;
  background: #fff;
  display: flex;
}

.card-checked {
  background: #f0faf4;
}

.card-left {
  margin-right: 16rpx;
  display: flex;
  align-items: flex-start;
  padding-top: 8rpx;
}

.checkbox {
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #ddd;
  box-sizing: border-box;
}

.checkbox.checked {
  background: #07c160;
  border-color: #07c160;
}

.card-main {
  flex: 1;
  min-width: 0;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.arrow {
  color: #bbb;
  font-size: 34rpx;
}

.card-body {
  display: flex;
  gap: 16rpx;
}

.card-thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.card-info {
  flex: 1;
  min-width: 0;
}

.meta {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.preview-text {
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

/* 批量操作栏 */
.batch-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #eee;
  z-index: 100;
}

.batch-count {
  font-size: 26rpx;
  color: #666;
  margin-right: auto;
}

.batch-btn {
  padding: 16rpx 32rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  margin-left: 16rpx;
}

.batch-btn.reject {
  background: #f5f5f5;
  color: #666;
}

.batch-btn.resolve {
  background: #07c160;
  color: #fff;
}
