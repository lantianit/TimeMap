.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  box-sizing: border-box;
}

.loading { text-align: center; color: #999; font-size: 28rpx; padding: 120rpx 0; }

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.title { font-size: 32rpx; font-weight: 600; color: #333; }

.status { font-size: 22rpx; padding: 8rpx 16rpx; border-radius: 999rpx; }
.status-0 { color: #fa8c16; background: rgba(250,140,22,0.12); }
.status-1 { color: #07c160; background: rgba(7,193,96,0.12); }
.status-2 { color: #666; background: #f0f0f0; }

.line { display: flex; margin-top: 10rpx; }
.label { width: 132rpx; color: #999; font-size: 24rpx; }
.value { flex: 1; color: #333; font-size: 24rpx; line-height: 1.7; }

.section-title { font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 18rpx; }

.photo {
  width: 100%; height: 360rpx;
  border-radius: 16rpx; background: #f0f0f0; margin-bottom: 16rpx;
}

.preview { display: block; color: #333; font-size: 24rpx; line-height: 1.7; }
.owner { margin-top: 14rpx; font-size: 24rpx; color: #666; }

.ghost-btn {
  margin-top: 18rpx;
  background: #f6fbf8; color: #07c160;
  border-radius: 12rpx; font-size: 26rpx;
}

.textarea {
  width: 100%; min-height: 180rpx;
  padding: 20rpx; box-sizing: border-box;
  background: #f8f9fb; border-radius: 16rpx;
  font-size: 26rpx; color: #333;
}

.handled {
  margin-top: 16rpx;
  display: flex; flex-direction: column; gap: 8rpx;
  font-size: 22rpx; color: #999;
}

.action-bar {
  display: flex; gap: 20rpx;
  margin-top: 20rpx; padding-bottom: 20rpx;
}

.reject-btn, .resolve-btn {
  flex: 1; height: 88rpx;
  border-radius: 44rpx; font-size: 30rpx;
}

.reject-btn { background: #fff; color: #666; }
.resolve-btn { background: linear-gradient(135deg, #07c160, #06ad56); color: #fff; }

/* 处罚选择 */
.punishment-section {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #fafbfc;
  border-radius: 16rpx;
}

.punishment-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}

.punishment-label { font-size: 26rpx; color: #666; }

.punishment-picker {
  font-size: 26rpx;
  color: #07c160;
  padding: 8rpx 16rpx;
  background: #f0faf4;
  border-radius: 8rpx;
}

.punishment-input {
  width: 120rpx;
  text-align: center;
  padding: 8rpx 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
}

/* 违规记录 */
.no-data { text-align: center; color: #ccc; font-size: 24rpx; padding: 20rpx 0; }

.violation-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 22rpx;
}

.violation-type {
  color: #fa8c16;
  background: rgba(250,140,22,0.1);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.violation-reason { flex: 1; color: #666; }
.violation-time { color: #bbb; }

.punish-action {
  margin-top: 16rpx;
  text-align: center;
  padding: 16rpx;
  background: #fff5f5;
  color: #e64340;
  border-radius: 12rpx;
  font-size: 26rpx;
}
